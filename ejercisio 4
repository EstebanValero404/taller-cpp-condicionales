 # include <iostream>
int main() {
    double num1, num2;
    char opt;
    cin >> num1;
    cout << "Ingrese el operador (+, -, *, /): ";
    cin >> opt;
    cout << "Ingrese el segundo numero: ";
    cin >> num2;
    if (opt == '+') {
        cout << "Resultado: " << num1 + num2;
    }
    else if (opt == '-') {
        cout << "Resultado: " << num1 - num2;
    }
    else if (opt == '*') {
        cout << "Resultado: " << num1 * num2;
    }
    else if (opt == '/') {
        if (num2 != 0) {
            cout << "Resultado: " << num1 / num2;
        } else {
            cout << "Error: no se puede dividir por cero";
        }
    }
    else {
        cout << "Operador no valido";
    }

    return 0;
}
